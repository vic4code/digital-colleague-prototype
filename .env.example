# ---------------------------------------------------------------------------
# Digital Colleague Prototype — environment configuration
#
# Copy to `.env` and fill in. NOTHING secret belongs in a colleague's info.yaml;
# info.yaml only *references* these variables by name. This keeps identity
# (person/soul/info) in git and secrets out of it.
# ---------------------------------------------------------------------------

# --- Agent runtime (the "brain" that executes a turn) ----------------------
# Which runtime to bind. One of: codex | claude-code | echo
# `echo` needs no keys and is useful for offline smoke tests.
DC_AGENT_RUNTIME=echo

# Path or command for the Codex runtime (the vendor agent CLI/app-server).
# The CodexRuntime shells out to this. Leave as `codex` if it's on your PATH.
CODEX_BIN=codex
CODEX_MODEL=gpt-5-codex

# If you instead bind the Claude Code runtime:
ANTHROPIC_API_KEY=
CLAUDE_CODE_MODEL=claude-opus-4-8

# --- Slack channel (info.yaml references these by name) --------------------
# Create a Slack app, install to workspace, use a bot token (xoxb-...).
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# --- Gmail channel (info.yaml references these by name) --------------------
# OAuth2 desktop/service credentials for the colleague's mailbox.
GMAIL_ADDRESS=
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
