# ---------------------------------------------------------------------------
# Digital Colleague Prototype — environment configuration
#
# Copy to `.env` only when a local runtime variable below is needed. NOTHING
# secret belongs in a colleague's info.yaml. Official workspace connectors keep
# OAuth state in Codex/ChatGPT rather than this repository.
# ---------------------------------------------------------------------------

# --- Agent runtime (the "brain" that executes a turn) ----------------------
# Which runtime to bind. One of: codex | claude-code | echo
# `echo` needs no keys and is useful for offline smoke tests.
DC_AGENT_RUNTIME=echo

# Path or command for the Codex CLI. The runtime starts its native app-server
# over stdio. Leave as `codex` if it is on your PATH.
CODEX_BIN=codex
# Optional. Leave unset to use the model selected by the installed Codex app.
# CODEX_MODEL=

# If you instead bind the Claude Code runtime:
ANTHROPIC_API_KEY=
CLAUDE_CODE_MODEL=claude-opus-4-8

# Gmail/Outlook Email, Google/Outlook Calendar, Notion, and Slack use their
# official Codex/ChatGPT plugin OAuth flows. Do not copy those credentials into
# this file.
