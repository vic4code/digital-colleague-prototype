# Generate every secret independently; never reuse one token at another trust
# boundary. `openssl rand -hex 32` is suitable for the four bearer tokens.
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_HOOK_TOKEN=
DC_EVENT_INGRESS_TOKEN=
GMAIL_PUSH_TOKEN=

# Separate Google/gog identity. This is intentionally independent of the
# Codex/ChatGPT account used by the OpenClaw Codex harness.
ADA_GMAIL_ACCOUNT=cathayaids@gmail.com
GOG_KEYRING_PASSWORD=

# The guard plugin projects task state to the local prototype API. On Docker
# Desktop and Linux Compose, host.docker.internal reaches the host service.
ADA_EVENT_API_URL=http://host.docker.internal:8787/api/v1/events

# Host-only settings used by Docker Compose.
# On POSIX hosts, replace these with the output of `id -u` and `id -g`.
# Windows Docker runs through WSL 2, where the normal first user is usually 1000.
OPENCLAW_UID=1000
OPENCLAW_GID=1000
OPENCLAW_HOST_STATE_DIR=../../.state/openclaw
OPENCLAW_HOST_AUTH_SECRET_DIR=../../.state/openclaw-home/.config/openclaw
GOG_HOST_STATE_DIR=../../.state/gogcli
OPENCLAW_GATEWAY_PORT=18889
OPENCLAW_INGRESS_PORT=18890

# Slack HTTP mode. Keep the channel patch disabled until these values and the
# exact Slack user/channel IDs have been configured.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
